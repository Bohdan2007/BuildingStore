<!DOCTYPE html>
    <html lang="ua">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Оплата - Z-Build</title>
        <link rel="stylesheet" href="~/css/payment.css" asp-append-version="true" />
    </head>
    <body>

        <div class="payment-container">
            <div class="payment-form">

                <div class="payment-header">
                    <div class="label-text">Оплата замовлення</div>
                    <div class="total-price">До сплати: 4 500 ₴</div>
                </div>

                <div class="error-message">
                    Помилка: Користувача з таким ПІБ не знайдено. Спочатку зареєструйтесь.
                </div>

                <div class="input-group">
                    <label>ПІБ власника</label>
                    <input type="text" spellcheck="false" placeholder="Введіть ваше ПІБ" />
                </div>

                <div class="input-group">
                    <label>Номер поштомату (Нова Пошта)</label>
                    <input type="text" placeholder="Введіть номер поштомату" />
                </div>

                <div class="input-group">
                    <label>Номер картки</label>
                    <input type="text" placeholder="0000 0000 0000 0000" maxlength="19" />
                </div>

                <div class="row-inputs">
                    <div class="input-group">
                        <label>Термін дії</label>
                        <input type="text" placeholder="ММ / РР" maxlength="5" />
                    </div>
                    <div class="input-group">
                        <label>CVV</label>
                        <input type="password" placeholder="***" maxlength="3" />
                    </div>
                </div>

                <a href="/Basket/Success" class="btn-pay">Підтвердити та оплатити</a>

                <a href="/Basket/Basket" class="btn-back">Скасувати та повернутися</a>

            </div>
        </div>

    </body>
</html>