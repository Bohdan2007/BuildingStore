@model Tuple<BuildingStore.Models.Product, List<BuildingStore.Models.Category>>

<!DOCTYPE html>
<html lang="ua">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Додати товар - Z-Build</title>
    <link rel="stylesheet" href="~/css/addProduct.css" asp-append-version="true" />
</head>
<body>

    <div class="admin-container">

        <header class="header">
            <a href="/User/AdminProfile" class="btn-back">Назад до панелі</a>
            <h1 class="title">Новий товар</h1>
        </header>

        <main class="form-card">

            @{
                var firstError = ViewData.ModelState.Values.SelectMany(v => v.Errors).FirstOrDefault()?.ErrorMessage;
            }

            @if (!string.IsNullOrEmpty(firstError))
            {
                <div class="error-message">
                    @firstError
                </div>
            }

            <form asp-controller="Products" asp-action="AddProduct" method="post" enctype="multipart/form-data" class="product-form">

                <div class="input-group">
                    <label>Назва товару</label>
                    <input type="text" name="Name" value="@Model.Item1.Name" placeholder="Наприклад: Професійний перфоратор" spellcheck="false" />
                </div>

                <div class="row-inputs">
                    <div class="input-group">
                        <label>Ціна (₴)</label>
                        <input type="number" step="0.01" name="Price" value="@(Model.Item1.Price > 0 ? Model.Item1.Price.ToString().Replace(",", ".") : "")" placeholder="0.00" class="price-input" />
                    </div>
                    <div class="input-group">
                        <label>Категорія</label>
                        <select name="CategoryId">
                            <option value="">Оберіть категорію...</option>
                            @foreach (var category in Model.Item2)
                            {
                                if (Model.Item1.CategoryId == category.Id)
                                {
                                    <option value="@category.Id" selected>@category.Name</option>
                                }
                                else
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <div class="input-group">
                    <label>Опис товару</label>
                    <textarea name="Description" class="textarea" placeholder="Детально опишіть характеристики товару..." rows="5">@Model.Item1.Description</textarea>
                </div>

                <div class="input-group">
                    <label>Фото товару</label>
                    <div class="file-upload-wrapper">
                        <input type="file" name="photo" accept="image/*" class="file-input" />
                    </div>
                </div>

                <button type="submit" class="btn-save">Створити товар</button>

            </form>
        </main>

    </div>

</body>
</html>