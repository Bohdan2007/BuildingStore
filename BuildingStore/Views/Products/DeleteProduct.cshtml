@model Tuple<List<BuildingStore.Models.Product>, List<BuildingStore.Models.Category>, string, int?>

<!DOCTYPE html>
<html lang="ua">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Видалити товар - Z-Build</title>
    <link rel="stylesheet" href="~/css/deleteProduct.css" asp-append-version="true" />
</head>
<body>

    <div class="admin-container">

        <header class="header">
            <a href="/User/AdminProfile" class="btn-back">Назад до панелі</a>
            <h1 class="title">Видалення товару</h1>
        </header>

        <main class="management-card">
            <form method="get" controller="Products" action="DeleteProduct" class="search-section">
                <div class="row-inputs">
                    <div class="input-group">
                        <label>Категорія</label>
                        <select name="categoryId">
                            <option value="0">Усі категорії</option>
                            @foreach (var category in Model.Item2)
                            {
                                if (Model.Item4 == category.Id)
                                {
                                    <option value="@category.Id" selected>@category.Name</option>
                                }
                                else
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="input-group">
                        <label>Назва товару</label>
                        <input type="text" name="searchName" value="@Model.Item3" placeholder="Введіть назву для пошуку..." spellcheck="false" />
                    </div>
                </div>
                <button type="submit" class="btn-search">Знайти товар</button>
            </form>

            <div class="search-result">

                @if (Model.Item1 != null && Model.Item1.Any())
                {
                    foreach (var product in Model.Item1)
                    {
                        <div class="product-preview">
                            <div class="preview-image">
                                @if (!string.IsNullOrEmpty(product.Photo))
                                {
                                    <img src="~/images/@product.Photo" alt="Фото" />
                                }
                                else
                                {
                                    <span>Немає</span>
                                }
                            </div>
                            <div class="preview-info">
                                <div class="product-name">@product.Name</div>
                                <div class="product-price">@product.Price.ToString("N0") ₴</div>
                            </div>

                            <form controller="Products" action="ConfirmDelete" method="post">
                                <input type="hidden" name="id" value="@product.Id" />
                                <button type="submit" class="btn-delete">Видалити товар</button>
                            </form>
                        </div>
                    }
                }
                else if (!string.IsNullOrEmpty(Model.Item3) || (Model.Item4.HasValue && Model.Item4 > 0))
                {
                    <div class="no-results">
                        За вашим запитом товарів не знайдено.
                    </div>
                }

            </div>
        </main>

    </div>

</body>
</html>