<!DOCTYPE html>
<html lang="ua">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Мій кабінет - Z-Build</title>
        <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
    </head>
    <body>

        <div class="profile-container">

            <header class="profile-header">
                <h1 class="title">Мій кабінет</h1>
                <a href="/Products/Products" class="btn-exit">Вийти</a>
            </header>

            <main class="profile-content">

                <section class="user-info-card">
                    <div class="user-avatar">👤</div>
                    <div class="user-details">
                        <div class="user-name">@Model.Name</div>
                        <div class="user-email">@Model.Email</div>
                    </div>
                </section>

                <section class="orders-section">
                    <h2 class="section-title">Історія замовлень</h2>

                    <div class="orders-list">
                        @if (Model.Orders == null || Model.Orders.Count == 0)
                        {
                            <p class="zero-orders">У вас ще немає виконаних замовлень.</p>
                        }
                        else
                        {
                            @foreach (var order in Model.Orders)
                            {
                                @foreach (var item in order.OrderItems)
                                {
                                    <div class="order-item">
                                        <div class="order-main">
                                            <span class="order-date">@order.OrderDate.ToString("dd.MM.yyyy")</span>
                                            <span class="order-status">Виконано</span>
                                        </div>
                                        <div class="order-info">
                                            <span class="order-name">@item.Product.Name (@item.Quantity)</span>
                                        <span class="order-price">@((item.Price* item.Quantity).ToString("N0")) ₴</span>
                                        </div>
                                    </div>
                                }
                            }
                        }
                    </div>

                </section>

            </main>

        </div>

    </body>
</html>